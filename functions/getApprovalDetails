import { createClientFromRequest } from "npm:@base44/sdk@0.7.1";

Deno.serve(async (req) => {
  const debug = [];
  
  try {
    const base44 = createClientFromRequest(req);
    const currentUser = await base44.auth.me();

    if (!currentUser) {
      return Response.json({ ok: false, error: "Unauthorized" }, { status: 401 });
    }

    const users = await base44.asServiceRole.entities.User.filter({ email: currentUser.email });
    const user = users[0];

    if (!user?.pco_access_token) {
      return Response.json({ ok: false, error: "No PCO token" }, { status: 401 });
    }

    const { request_id, event_id, resource_id } = await req.json();
    
    const headers = { 
      Authorization: `Bearer ${user.pco_access_token}`,
      "Content-Type": "application/json" 
    };

    // Step 1: Get the EventResourceRequest to find its ResourceBooking ID
    debug.push({ step: 1, action: "Getting request to find booking_id" });
    
    const reqUrl = `https://api.planningcenteronline.com/calendar/v2/event_resource_requests/${request_id}`;
    const reqRes = await fetch(reqUrl, { headers });
    const reqJson = await reqRes.json();
    
    const bookingId = reqJson.data?.relationships?.resource_booking?.data?.id;
    debug.push({ 
      step: 1, 
      result: "Request fetched",
      booking_id: bookingId,
      has_booking: !!bookingId
    });

    if (!bookingId) {
      return Response.json({
        ok: false,
        error: "No resource_booking found on this request",
        debug
      });
    }

    // Step 2: Get the ResourceBooking with ALL its question answers
    debug.push({ step: 2, action: "Fetching booking with answers", booking_id: bookingId });
    
    const bookingUrl = `https://api.planningcenteronline.com/calendar/v2/resource_bookings/${bookingId}?include=resource_question_answers,resource_question_answers.resource_question,resource_question_answers.choice`;
    const bookingRes = await fetch(bookingUrl, { headers });
    const bookingJson = await bookingRes.json();
    
    debug.push({
      step: 2,
      result: "Booking fetched",
      data_exists: !!bookingJson.data,
      included_count: bookingJson.included?.length || 0,
      included_types: [...new Set((bookingJson.included || []).map(x => x.type))]
    });

    // Step 3: Extract ResourceQuestionAnswers
    const answerObjects = (bookingJson.included || []).filter(x => x.type === "ResourceQuestionAnswer");
    debug.push({
      step: 3,
      action: "Extracting answers",
      answer_objects_found: answerObjects.length,
      raw_answers: answerObjects.map(a => ({
        id: a.id,
        attributes: a.attributes,
        relationships: a.relationships
      }))
    });

    // Step 4: Get questions
    const qUrl = `https://api.planningcenteronline.com/calendar/v2/resources/${resource_id}/resource_questions`;
    const qRes = await fetch(qUrl, { headers });
    const qJson = await qRes.json();
    
    const questions = (qJson.data || []).map(q => ({
      id: q.id,
      question: q.attributes?.question,
      description: q.attributes?.description,
      kind: q.attributes?.kind
    }));
    
    debug.push({ step: 4, action: "Questions fetched", count: questions.length });

    // Step 5: Map answers
    const answersMap = {};
    const includedMap = new Map((bookingJson.included || []).map(x => [`${x.type}:${x.id}`, x]));
    
    for (const ansObj of answerObjects) {
      const questionId = ansObj.relationships?.resource_question?.data?.id;
      
      if (!questionId) {
        debug.push({ warning: "Answer has no question relationship", answer_id: ansObj.id });
        continue;
      }
      
      // Try all possible answer fields
      let value = 
        ansObj.attributes?.answer_text ||
        ansObj.attributes?.answer ||
        ansObj.attributes?.value ||
        ansObj.attributes?.answer_number ||
        ansObj.attributes?.answer_boolean ||
        ansObj.attributes?.answer_choice;
      
      // If still no value, try the choice relationship
      if (!value && ansObj.relationships?.choice?.data?.id) {
        const choiceId = ansObj.relationships.choice.data.id;
        const choiceObj = includedMap.get(`Choice:${choiceId}`);
        value = choiceObj?.attributes?.name || choiceObj?.attributes?.value;
      }
      
      if (value !== null && value !== undefined) {
        answersMap[questionId] = String(value);
        debug.push({ 
          step: 5, 
          mapped: `Q${questionId} = "${value}"` 
        });
      }
    }

    return Response.json({
      ok: true,
      questions,
      answers: answersMap,
      totals: {
        questions: questions.length,
        answers: Object.keys(answersMap).length
      },
      debug
    });

  } catch (err) {
    console.error("Error:", err);
    return Response.json({
      ok: false,
      error: String(err),
      debug
    }, { status: 500 });
  }
});