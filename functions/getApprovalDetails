import { createClientFromRequest } from "npm:@base44/sdk@0.7.1";

/**
 * getApprovalDetails
 * Retrieves resource questions, answers, and event info for a Planning Center approval.
 * Works even when answers are nested under resource_bookings or event_resource_requests.
 */

Deno.serve(async (req) => {
  const diag = [];
  try {
    const base44 = createClientFromRequest(req);
    const user = await base44.auth.me();
    diag.push({ step: "auth", user_email: user?.email });

    if (!user?.pco_access_token) {
      diag.push({ step: "auth", error: "missing pco_access_token" });
      return Response.json({ ok: false, error: "Unauthorized", diag }, { status: 401 });
    }

    const { request_id, resource_id, event_id } = await req.json();
    if (!event_id || !resource_id) {
      return Response.json({
        ok: false,
        error: "Missing event_id or resource_id",
        diag,
      }, { status: 400 });
    }

    const headers = {
      Authorization: `Bearer ${user.pco_access_token}`,
      "Content-Type": "application/json",
    };

    // 🔹 Step 1: Fetch Resource Questions
    const qUrl = `https://api.planningcenteronline.com/calendar/v2/resources/${resource_id}/resource_questions`;
    const qRes = await fetch(qUrl, { headers });
    const questionsData = qRes.ok ? await qRes.json() : { data: [] };

    const questions = (questionsData.data || []).map(q => ({
      id: q.id,
      question: q.attributes.question,
      description: q.attributes.description,
      kind: q.attributes.kind,
      choices: q.attributes.choices,
      multiple_select: q.attributes.multiple_select,
      optional: q.attributes.optional,
    }));
    diag.push({ step: "questions", count: questions.length });

    // 🔹 Step 2: Try to fetch Answers by request
    const aUrl = `https://api.planningcenteronline.com/calendar/v2/event_resource_requests/${request_id}/resource_answers`;
    const aRes = await fetch(aUrl, { headers });

    const answers = {};
    if (aRes.ok) {
      const aData = await aRes.json();
      diag.push({ step: "answers", count: aData.data?.length || 0 });

      (aData.data || []).forEach((a) => {
        const qid = a.relationships?.resource_question?.data?.id;
        if (!qid) return;
        let val =
          a.attributes?.answer_text ??
          a.attributes?.answer_number ??
          a.attributes?.answer_boolean ??
          a.attributes?.answer_choice ??
          a.attributes?.answer ??
          null;
        if (typeof val === "object" && val?.attributes?.name) val = val.attributes.name;
        if (qid && val !== null) answers[qid] = val;
      });
    } else {
      diag.push({ step: "answers", status: aRes.status });
    }

    // 🔹 Step 3: If no answers, fetch via event bookings fallback
    if (Object.keys(answers).length === 0) {
      const bookingsUrl = `https://api.planningcenteronline.com/calendar/v2/events/${event_id}/resource_bookings?include=resource_question_answers.resource_question,resource_question_answers.choice`;
      const bRes = await fetch(bookingsUrl, { headers });
      if (bRes.ok) {
        const bData = await bRes.json();
        const included = bData.included || [];
        const answerItems = included.filter(i => i.type === "ResourceQuestionAnswer");

        diag.push({ step: "bookings-fallback", answersFound: answerItems.length });

        for (const a of answerItems) {
          const qid = a.relationships?.resource_question?.data?.id;
          if (!qid) continue;
          let val =
            a.attributes?.answer_text ??
            a.attributes?.answer_number ??
            a.attributes?.answer_boolean ??
            a.attributes?.answer_choice ??
            a.attributes?.answer ??
            null;
          if (typeof val === "object" && val?.attributes?.name) val = val.attributes.name;
          if (qid && val !== null) answers[qid] = val;
        }
      }
    }

    // 🔹 Step 4: Fetch Event Summary
    const eUrl = `https://api.planningcenteronline.com/calendar/v2/events/${event_id}`;
    const eRes = await fetch(eUrl, { headers });
    let event = null;
    if (eRes.ok) {
      const eData = await eRes.json();
      event = {
        id: eData.data?.id,
        name: eData.data?.attributes?.name,
        starts_at: eData.data?.attributes?.starts_at,
        ends_at: eData.data?.attributes?.ends_at,
        summary: eData.data?.attributes?.summary,
        description: eData.data?.attributes?.description,
        percent_approved: eData.data?.attributes?.percent_approved,
      };
    }

    diag.push({
      step: "return",
      totals: {
        questions: questions.length,
        answers: Object.keys(answers).length,
      },
    });

    return Response.json({
      ok: true,
      event,
      questions,
      answers,
      diag,
    });
  } catch (error) {
    console.error("❌ getApprovalDetails error:", error);
    return Response.json({
      ok: false,
      error: String(error),
      diag,
    }, { status: 500 });
  }
});