import { createClientFromRequest } from 'npm:@base44/sdk@0.7.1';

Deno.serve(async (req) => {
  const diag = [];

  try {
    const base44 = createClientFromRequest(req);
    const currentUser = await base44.auth.me();

    if (!currentUser) {
      return Response.json({ error: 'Unauthorized' }, { status: 401 });
    }

    const { event_id, resource_id, request_id } = await req.json();

    if (!event_id || !resource_id) {
      return Response.json({
        ok: false,
        error: "Missing event_id or resource_id"
      }, { status: 400 });
    }

    // 🔑 Get Planning Center access token
    const tokenResponse = await base44.functions.invoke("getPCOToken");
    const access_token = tokenResponse.data.access_token;
    const headers = { Authorization: `Bearer ${access_token}` };

    // 🧩 Step 1: Fetch event with includes
    const eventUrl =
      `https://api.planningcenteronline.com/calendar/v2/events/${event_id}` +
      `?include=resource_bookings,resource_bookings.resource,` +
      `resource_bookings.resource_question_answers.resource_question,` +
      `resource_bookings.resource_question_answers.choice`;

    const eventRes = await fetch(eventUrl, { headers });
    const eventJson = await eventRes.json();
    diag.push({
      step: "event",
      status: eventRes.status,
      included: eventJson.included?.length || 0
    });

    const included = Object.fromEntries((eventJson.included || []).map(x => [x.id, x]));
    let answers = (eventJson.included || []).filter(x => x.type === "ResourceQuestionAnswer");

    // 🧩 Step 2: If no answers found, fetch bookings directly
    if (!answers.length) {
      const bookUrl =
        `https://api.planningcenteronline.com/calendar/v2/events/${event_id}/resource_bookings` +
        `?include=resource,resource_question_answers.resource_question,resource_question_answers.choice`;

      const bookRes = await fetch(bookUrl, { headers });
      const bookJson = await bookRes.json();
      answers = (bookJson.included || []).filter(x => x.type === "ResourceQuestionAnswer");
      diag.push({
        step: "bookings",
        status: bookRes.status,
        answersFound: answers.length
      });
    }

    // 🧩 Step 3: Get resource questions for this resource
    const qUrl = `https://api.planningcenteronline.com/calendar/v2/resources/${resource_id}/resource_questions`;
    const qRes = await fetch(qUrl, { headers });
    const qJson = await qRes.json();
    const questions = (qJson.data || []).map(q => ({
      id: q.id,
      question: q.attributes.question,
      description: q.attributes.description,
      required: q.attributes.required
    }));
    diag.push({ step: "questions", count: questions.length });

    // 🧩 Step 4: Map answers to question IDs
    const mappedAnswers = {};
    for (const a of answers) {
      const qid = a.relationships?.resource_question?.data?.id;
      const val =
        a.attributes?.answer_text ||
        a.attributes?.answer_number ||
        a.attributes?.answer_boolean ||
        a.attributes?.answer_choice ||
        null;
      if (qid && val !== null) mappedAnswers[qid] = val;
    }

    diag.push({
      step: "map",
      mapped: Object.keys(mappedAnswers).length
    });

    // ✅ Return clean JSON
    return Response.json({
      ok: true,
      event: eventJson.data || null,
      questions,
      answers: mappedAnswers,
      totals: {
        questions: questions.length,
        answers: Object.keys(mappedAnswers).length
      },
      diag
    });

  } catch (err) {
    console.error("❌ getApprovalDetails failed:", err);
    return Response.json({
      ok: false,
      error: String(err),
      diag
    }, {
      status: 500
    });
  }
});