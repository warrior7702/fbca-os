import { createClientFromRequest } from 'npm:@base44/sdk@0.7.1';

Deno.serve(async (req) => {
  const log = [];

  try {
    const base44 = createClientFromRequest(req);
    const currentUser = await base44.auth.me();

    if (!currentUser) {
      return Response.json({ error: 'Unauthorized' }, { status: 401 });
    }

    const { event_id, resource_id, request_id } = await req.json();
    log.push({ step: 'START', event_id, resource_id, request_id });

    if (!event_id || !resource_id) {
      return Response.json({
        ok: false,
        error: "Missing event_id or resource_id",
        log
      }, { status: 400 });
    }

    // Get PCO token
    const tokenResponse = await base44.functions.invoke("getPCOToken");
    const token = tokenResponse.data.access_token;
    const headers = { 
      Authorization: `Bearer ${token}`,
      'Content-Type': 'application/json'
    };

    // Step 1: Get resource questions
    console.log('📋 Step 1: Getting resource questions...');
    const qUrl = `https://api.planningcenteronline.com/calendar/v2/resources/${resource_id}/resource_questions?per_page=100`;
    const qRes = await fetch(qUrl, { headers });
    const qJson = await qRes.json();
    
    const questions = (qJson.data || []).map(q => ({
      id: q.id,
      question: q.attributes?.question || q.attributes?.name || "Unnamed Question",
      description: q.attributes?.description || "",
      required: q.attributes?.required || false
    }));
    
    log.push({ step: 'QUESTIONS', count: questions.length, ids: questions.map(q => q.id) });
    console.log(`✅ Found ${questions.length} questions:`, questions.map(q => `${q.id}: ${q.question}`));

    // Step 2: Get ALL bookings for this event with ALL includes
    console.log('📥 Step 2: Getting bookings for event...');
    const bookUrl = 
      `https://api.planningcenteronline.com/calendar/v2/events/${event_id}/resource_bookings?` +
      `per_page=100&` +
      `include=resource,resource_question_answers,resource_question_answers.resource_question,resource_question_answers.choice`;
    
    const bookRes = await fetch(bookUrl, { headers });
    const bookJson = await bookRes.json();
    
    log.push({ 
      step: 'BOOKINGS_FETCH', 
      status: bookRes.status,
      data_count: (bookJson.data || []).length,
      included_count: (bookJson.included || []).length
    });
    
    console.log(`✅ Bookings response:`, {
      bookings: (bookJson.data || []).length,
      included: (bookJson.included || []).length
    });

    // Step 3: Find the booking for our specific resource
    const targetBooking = (bookJson.data || []).find(b => {
      const resId = b.relationships?.resource?.data?.id;
      return resId === String(resource_id);
    });

    if (!targetBooking) {
      log.push({ step: 'ERROR', msg: 'No booking found for resource', resource_id });
      console.log('❌ No booking found for resource:', resource_id);
    } else {
      log.push({ step: 'BOOKING_FOUND', booking_id: targetBooking.id });
      console.log('✅ Found booking:', targetBooking.id);
    }

    // Step 4: Extract ALL ResourceQuestionAnswer objects from included
    const allAnswerObjects = (bookJson.included || []).filter(x => x.type === "ResourceQuestionAnswer");
    log.push({ step: 'ALL_ANSWERS', count: allAnswerObjects.length });
    console.log(`📝 Found ${allAnswerObjects.length} total answer objects in included`);

    // Step 5: Map answers to question IDs
    const answersMap = {};
    
    for (const ansObj of allAnswerObjects) {
      const questionId = ansObj.relationships?.resource_question?.data?.id;
      
      // Try ALL possible answer fields
      const answerValue = 
        ansObj.attributes?.answer_text ||
        ansObj.attributes?.answer ||
        ansObj.attributes?.value_text ||
        ansObj.attributes?.value ||
        ansObj.attributes?.answer_number ||
        ansObj.attributes?.answer_boolean ||
        ansObj.attributes?.answer_choice ||
        "";
      
      if (questionId && answerValue !== "" && answerValue !== null && answerValue !== undefined) {
        // Convert boolean/number to string
        answersMap[questionId] = String(answerValue);
        console.log(`   ✅ Mapped Q${questionId} = "${answerValue}"`);
      }
    }
    
    log.push({ step: 'ANSWERS_MAPPED', count: Object.keys(answersMap).length, keys: Object.keys(answersMap) });
    console.log(`✅ Total answers mapped: ${Object.keys(answersMap).length}`);

    // Step 6: Get event details
    const eventUrl = `https://api.planningcenteronline.com/calendar/v2/events/${event_id}`;
    const eventRes = await fetch(eventUrl, { headers });
    const eventJson = await eventRes.json();

    const event = {
      id: eventJson.data?.id,
      name: eventJson.data?.attributes?.name,
      approval_status: eventJson.data?.attributes?.approval_status,
      starts_at: eventJson.data?.attributes?.starts_at,
      ends_at: eventJson.data?.attributes?.ends_at,
      summary: eventJson.data?.attributes?.summary
    };

    // Return results
    return Response.json({
      ok: true,
      event,
      questions,
      answers: answersMap,
      totals: {
        questions: questions.length,
        answers: Object.keys(answersMap).length
      },
      log
    });

  } catch (err) {
    console.error("❌ Error:", err);
    return Response.json({
      ok: false,
      error: String(err),
      log
    }, { status: 500 });
  }
});