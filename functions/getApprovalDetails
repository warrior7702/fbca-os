import { createClientFromRequest } from "npm:@base44/sdk@0.7.1";

Deno.serve(async (req) => {
  const diag = [];
  
  try {
    const base44 = createClientFromRequest(req);
    const currentUser = await base44.auth.me();

    if (!currentUser) {
      return Response.json({ ok: false, error: "Unauthorized" }, { status: 401 });
    }

    const { request_id, event_id, resource_id } = await req.json();
    
    diag.push({ step: "input", request_id, event_id, resource_id });

    // Get PCO token (handles refresh automatically)
    diag.push({ step: "getting-token" });
    const tokenResponse = await base44.functions.invoke("getPCOToken");
    const token = tokenResponse.data.access_token;
    diag.push({ step: "token-obtained", has_token: !!token });

    const headers = { 
      Authorization: `Bearer ${token}`,
      "Content-Type": "application/json" 
    };

    async function pcoGet(url) {
      const r = await fetch(url, { headers });
      const text = await r.text();
      let json;
      try { json = JSON.parse(text || "{}"); } catch { json = { non_json: true, body: text }; }
      if (!r.ok) throw new Error(`GET ${url} :: ${r.status} :: ${JSON.stringify(json).slice(0, 800)}`);
      return json;
    }

    const normalize = (val) => {
      if (Array.isArray(val)) return val.map(v => (v?.attributes?.name ?? String(v))).join(", ");
      if (val && typeof val === "object") return val.attributes?.name ?? JSON.stringify(val);
      if (val === true) return "Yes";
      if (val === false) return "No";
      if (val === 0) return "0";
      return (val ?? "").toString();
    };

    // 1) Pull the resource questions (for labels)
    let questions = [];
    try {
      const q = await pcoGet(`https://api.planningcenteronline.com/calendar/v2/resources/${resource_id}/resource_questions`);
      questions = (q.data || []).map(q => ({
        id: q.id,
        question: q.attributes?.question,
        description: q.attributes?.description,
        kind: q.attributes?.kind,
        choices: q.attributes?.choices,
        multiple_select: q.attributes?.multiple_select,
        optional: q.attributes?.optional
      }));
      diag.push({ step: "questions", count: questions.length });
    } catch (e) {
      diag.push({ step: "questions-error", error: String(e) });
    }

    const answers = {};

    // 2) PRIMARY: answers from the specific request include
    if (request_id) {
      try {
        const reqJson = await pcoGet(
          `https://api.planningcenteronline.com/calendar/v2/event_resource_requests/${request_id}` +
          `?include=resource_question_answers.resource_question,resource_question_answers.choice`
        );
        const included = new Map((reqJson.included || []).map(x => [`${x.type}:${x.id}`, x]));
        const rqa = (reqJson.included || []).filter(x => x.type === "ResourceQuestionAnswer");

        diag.push({ step: "answers-request-raw", answer_count: rqa.length });

        for (const a of rqa) {
          const qRel = a.relationships?.resource_question?.data;
          if (!qRel?.id) continue;
          const raw =
            a.attributes?.answer_text ??
            a.attributes?.answer_number ??
            a.attributes?.answer_boolean ??
            a.attributes?.answer_choice ??
            a.attributes?.answer ??
            a.attributes?.value ?? null;
          if (raw !== null && raw !== undefined) {
            answers[qRel.id] = normalize(raw);
          } else {
            const cRel = a.relationships?.choice?.data;
            if (cRel?.id) {
              const inc = included.get(`${cRel.type}:${cRel.id}`);
              if (inc?.attributes?.name) answers[qRel.id] = inc.attributes.name;
            }
          }
        }
        diag.push({ step: "answers-request", found: Object.keys(answers).length });
      } catch (e) {
        diag.push({ step: "answers-request-error", error: String(e) });
      }
    }

    // 3) REQUEST-MATCHED FALLBACK: answers from the booking that belongs to THIS request
    if (!Object.keys(answers).length) {
      try {
        const bUrl =
          `https://api.planningcenteronline.com/calendar/v2/events/${event_id}/resource_bookings` +
          `?per_page=100` +
          `&include=` +
          [
            "resource",
            "event_resource_request",
            "resource_question_answers.resource_question",
            "resource_question_answers.choice",
          ].join(",");

        const bJson = await pcoGet(bUrl);

        // Build an index of included items
        const included = new Map((bJson.included || []).map(x => [`${x.type}:${x.id}`, x]));

        // Pull the bookings data array
        const bookings = Array.isArray(bJson.data) ? bJson.data : [];

        diag.push({ step: "bookings-fetched", count: bookings.length });

        // Try to find the booking whose event_resource_request matches our request_id
        const matched = bookings.find(b => {
          const reqRel = b?.relationships?.event_resource_request?.data;
          return reqRel?.id === request_id;
        });

        // If not found, fall back to same resource_id on this event
        const fallback = !matched
          ? bookings.find(b => {
              const resRel = b?.relationships?.resource?.data;
              return resRel?.id === resource_id;
            })
          : null;

        const targetBooking = matched || fallback || null;

        if (targetBooking) {
          // Extract answers for the target booking from INCLUDED
          const answerItems = (bJson.included || []).filter(x => x.type === "ResourceQuestionAnswer");
          
          diag.push({ step: "all-answer-objects", count: answerItems.length });
          
          // We only want answers that belong to the target booking:
          const targetAnswerIds = new Set(
            (targetBooking.relationships?.resource_question_answers?.data || []).map(d => d.id)
          );

          diag.push({ step: "target-booking-answer-ids", count: targetAnswerIds.size });

          const mine = answerItems.filter(a => targetAnswerIds.has(a.id));
          
          diag.push({ step: "filtered-answers", count: mine.length });
          
          for (const a of mine) {
            const qRel = a.relationships?.resource_question?.data;
            if (!qRel?.id) continue;

            let raw =
              a.attributes?.answer_text ??
              a.attributes?.answer_number ??
              a.attributes?.answer_boolean ??
              a.attributes?.answer_choice ??
              a.attributes?.answer ??
              a.attributes?.value ?? null;

            // Resolve choice name if needed
            if ((raw === null || typeof raw === "object") && a.relationships?.choice?.data) {
              const cRel = a.relationships.choice.data;
              const inc = included.get(`${cRel.type}:${cRel.id}`);
              if (inc?.attributes?.name) raw = inc.attributes.name;
            }

            if (raw !== null && raw !== undefined) {
              answers[qRel.id] = normalize(raw);
              diag.push({ step: "answer-mapped", question_id: qRel.id, value: String(raw).substring(0, 50) });
            }
          }
          diag.push({
            step: "answers-bookings-request-matched",
            matchedBooking: matched?.id || null,
            fallbackBooking: (!matched && fallback) ? fallback.id : null,
            found: Object.keys(answers).length
          });
        } else {
          diag.push({ step: "answers-bookings-request-matched", matchedBooking: null, found: 0 });
        }
      } catch (e) {
        diag.push({ step: "answers-bookings-request-matched-error", error: String(e) });
      }
    }

    // 4) Event summary
    let event = null;
    try {
      const eJson = await pcoGet(`https://api.planningcenteronline.com/calendar/v2/events/${event_id}`);
      event = {
        id: eJson.data?.id,
        name: eJson.data?.attributes?.name,
        starts_at: eJson.data?.attributes?.starts_at,
        ends_at: eJson.data?.attributes?.ends_at,
        percent_approved: eJson.data?.attributes?.percent_approved,
        approval_status: eJson.data?.attributes?.approval_status
      };
      diag.push({ step: "event", ok: true });
    } catch (e) {
      diag.push({ step: "event-error", error: String(e) });
    }

    return Response.json({
      ok: true,
      event,
      questions,
      answers,
      totals: { questions: questions.length, answers: Object.keys(answers).length },
      diag
    });
  } catch (err) {
    return Response.json({ ok: false, error: String(err), diag }, { status: 500 });
  }
});