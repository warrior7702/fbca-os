import { createClientFromRequest } from 'npm:@base44/sdk@0.7.1';

async function refreshTokenIfNeeded(base44, user) {
    const expiresAt = new Date(user.pco_token_expires_at);
    const fiveMinutesFromNow = new Date(Date.now() + 5 * 60 * 1000);

    if (expiresAt > fiveMinutesFromNow) {
        return user.pco_access_token;
    }

    const tokenResponse = await fetch('https://api.planningcenteronline.com/oauth/token', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams({
            grant_type: 'refresh_token',
            refresh_token: user.pco_refresh_token,
            client_id: Deno.env.get('PCO_CLIENT_ID'),
            client_secret: Deno.env.get('PCO_CLIENT_SECRET')
        })
    });

    if (!tokenResponse.ok) throw new Error('Token refresh failed');

    const tokens = await tokenResponse.json();
    const newExpiresAt = new Date(Date.now() + (tokens.expires_in * 1000)).toISOString();

    await base44.asServiceRole.entities.User.update(user.id, {
        pco_access_token: tokens.access_token,
        pco_refresh_token: tokens.refresh_token,
        pco_token_expires_at: newExpiresAt
    });

    return tokens.access_token;
}

Deno.serve(async (req) => {
    try {
        const base44 = createClientFromRequest(req);
        const currentUser = await base44.auth.me();

        if (!currentUser) {
            return Response.json({ error: 'Unauthorized' }, { status: 401 });
        }

        const users = await base44.asServiceRole.entities.User.filter({ email: currentUser.email });
        const user = users[0];

        if (!user || !user.pco_access_token) {
            return Response.json({ error: 'PCO not connected' }, { status: 400 });
        }

        const accessToken = await refreshTokenIfNeeded(base44, user);

        const { request_id, resource_id, event_id } = await req.json();

        console.log('🔍 Getting details for:');
        console.log('   Request ID:', request_id);
        console.log('   Resource ID:', resource_id);
        console.log('   Event ID:', event_id);

        // Fetch resource questions
        const questionsResponse = await fetch(
            `https://api.planningcenteronline.com/calendar/v2/resources/${resource_id}/resource_questions?per_page=100`,
            {
                headers: {
                    'Authorization': `Bearer ${accessToken}`,
                    'Content-Type': 'application/json'
                }
            }
        );

        let questions = [];
        if (questionsResponse.ok) {
            const questionsData = await questionsResponse.json();
            questions = questionsData.data.map(q => ({
                id: q.id,
                question: q.attributes.question,
                description: q.attributes.description,
                kind: q.attributes.kind,
                choices: q.attributes.choices,
                multiple_select: q.attributes.multiple_select,
                optional: q.attributes.optional
            }));
            console.log('✅ Found', questions.length, 'questions');
        } else {
            console.log('❌ Questions request failed:', questionsResponse.status);
        }

        // Get answers by drilling down: request → bookings → approval → answers
        const answers = {};
        
        console.log('\n📝 Fetching answers...');
        
        try {
            // Step 1: Get bookings for this request
            const bookingsResponse = await fetch(
                `https://api.planningcenteronline.com/calendar/v2/event_resource_requests/${request_id}/resource_bookings?per_page=100`,
                {
                    headers: {
                        'Authorization': `Bearer ${accessToken}`,
                        'Content-Type': 'application/json'
                    }
                }
            );
            
            if (bookingsResponse.ok) {
                const bookingsData = await bookingsResponse.json();
                console.log('✅ Found', bookingsData.data?.length || 0, 'bookings');
                
                // Step 2: For each booking, get its resource_approval
                for (const booking of bookingsData.data || []) {
                    const bookingId = booking.id;
                    console.log('   📦 Processing booking:', bookingId);
                    
                    const approvalResponse = await fetch(
                        `https://api.planningcenteronline.com/calendar/v2/resource_bookings/${bookingId}/resource_approval`,
                        {
                            headers: {
                                'Authorization': `Bearer ${accessToken}`,
                                'Content-Type': 'application/json'
                            }
                        }
                    );
                    
                    if (approvalResponse.ok) {
                        const approvalData = await approvalResponse.json();
                        const approvalId = approvalData.data?.id;
                        console.log('   ✅ Found approval:', approvalId);
                        
                        // Step 3: Get answers for this approval
                        if (approvalId) {
                            const answersResponse = await fetch(
                                `https://api.planningcenteronline.com/calendar/v2/resource_approvals/${approvalId}/resource_question_answers?per_page=100`,
                                {
                                    headers: {
                                        'Authorization': `Bearer ${accessToken}`,
                                        'Content-Type': 'application/json'
                                    }
                                }
                            );
                            
                            if (answersResponse.ok) {
                                const answersData = await answersResponse.json();
                                console.log('   ✅ Found', answersData.data?.length || 0, 'answer records');
                                
                                for (const answer of answersData.data || []) {
                                    const questionId = answer.relationships?.resource_question?.data?.id;
                                    
                                    // LOG THE FULL ANSWER OBJECT TO SEE WHAT'S IN IT
                                    console.log('      📄 Full answer object for Q' + questionId + ':', JSON.stringify(answer.attributes, null, 2));
                                    
                                    // Try multiple possible fields where the answer might be
                                    let answerValue = answer.attributes?.value 
                                        || answer.attributes?.body 
                                        || answer.attributes?.text
                                        || answer.attributes?.answer
                                        || '';
                                    
                                    // Handle array values (for multiple_select questions)
                                    if (Array.isArray(answerValue)) {
                                        answerValue = answerValue.join(', ');
                                    }
                                    
                                    if (questionId) {
                                        answers[questionId] = answerValue;
                                        console.log(`      ✅ Q${questionId} = "${answerValue}"`);
                                    }
                                }
                            } else {
                                console.log('   ⚠️ Answers request failed:', answersResponse.status);
                            }
                        }
                    } else {
                        console.log('   ⚠️ Approval request failed:', approvalResponse.status);
                    }
                }
            } else {
                console.log('❌ Bookings request failed:', bookingsResponse.status);
            }
        } catch (err) {
            console.error('❌ Error fetching answers:', err.message);
        }
        
        if (Object.keys(answers).length === 0) {
            console.log('\n⚠️ No answers found - requestor may not have filled out the form yet');
        }

        console.log('\n✅ Total answers found:', Object.keys(answers).length);

        // Fetch event details
        const eventResponse = await fetch(
            `https://api.planningcenteronline.com/calendar/v2/events/${event_id}`,
            {
                headers: {
                    'Authorization': `Bearer ${accessToken}`,
                    'Content-Type': 'application/json'
                }
            }
        );

        let event = null;
        if (eventResponse.ok) {
            const eventData = await eventResponse.json();
            event = {
                name: eventData.data.attributes.name,
                starts_at: eventData.data.attributes.starts_at,
                ends_at: eventData.data.attributes.ends_at,
                summary: eventData.data.attributes.summary,
                description: eventData.data.attributes.description
            };
            console.log('✅ Got event details');
        }

        console.log('\n🎯 Returning:');
        console.log('   Questions:', questions.length);
        console.log('   Answers:', Object.keys(answers).length);
        console.log('   Event:', !!event);

        return Response.json({
            questions,
            answers,
            event
        });

    } catch (error) {
        console.error('❌ Get approval details error:', error);
        return Response.json({ 
            error: error.message,
            questions: [],
            answers: {},
            event: null
        }, { status: 500 });
    }
});