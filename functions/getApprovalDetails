import { createClientFromRequest } from "npm:@base44/sdk@0.7.1";

Deno.serve(async (req) => {
  const diag = [];
  try {
    const base44 = createClientFromRequest(req);
    const user = await base44.auth.me();
    if (!user?.pco_access_token) {
      return Response.json({ ok: false, error: "Unauthorized: missing pco_access_token" }, { status: 401 });
    }

    const { request_id, event_id, resource_id } = await req.json();
    if (!event_id || !resource_id) {
      return Response.json({ ok: false, error: "Missing event_id or resource_id" }, { status: 400 });
    }
    diag.push({ step: "input", request_id, event_id, resource_id });

    const headers = {
      Authorization: `Bearer ${user.pco_access_token}`,
      "Content-Type": "application/json",
    };

    async function pcoGet(url) {
      const r = await fetch(url, { headers });
      const text = await r.text();
      let json;
      try { json = JSON.parse(text || "{}"); } catch { json = { non_json: true, body: text }; }
      if (!r.ok) throw new Error(`GET ${url} :: ${r.status} :: ${JSON.stringify(json).slice(0,800)}`);
      return json;
    }

    function normalizeAnswer(val) {
      if (Array.isArray(val)) return val.map(v => (v?.attributes?.name ?? String(v))).join(", ");
      if (val && typeof val === "object") return val.attributes?.name ?? JSON.stringify(val);
      if (val === true) return "Yes";
      if (val === false) return "No";
      if (val === 0) return "0";
      return (val ?? "").toString();
    }

    // 1) Resource questions (base text for the resource)
    let questions = [];
    try {
      const q = await pcoGet(`https://api.planningcenteronline.com/calendar/v2/resources/${resource_id}/resource_questions`);
      questions = (q.data || []).map(q => ({
        id: q.id,
        question: q.attributes?.question,
        description: q.attributes?.description,
        kind: q.attributes?.kind,
        choices: q.attributes?.choices,
        multiple_select: q.attributes?.multiple_select,
        optional: q.attributes?.optional
      }));
      diag.push({ step: "questions", count: questions.length });
    } catch (e) {
      diag.push({ step: "questions-error", error: String(e) });
    }

    const answers = {};

    // 2) PRIMARY: answers via the specific Event Resource Request
    if (request_id) {
      try {
        const reqJson = await pcoGet(
          `https://api.planningcenteronline.com/calendar/v2/event_resource_requests/${request_id}` +
          `?include=resource_question_answers.resource_question,resource_question_answers.choice`
        );

        const included = new Map((reqJson.included || []).map(x => [`${x.type}:${x.id}`, x]));
        const rqa = (reqJson.included || []).filter(x => x.type === "ResourceQuestionAnswer");

        for (const a of rqa) {
          const qRel = a.relationships?.resource_question?.data;
          if (!qRel?.id) continue;
          const raw =
            a.attributes?.answer_text ??
            a.attributes?.answer_number ??
            a.attributes?.answer_boolean ??
            a.attributes?.answer_choice ??
            a.attributes?.answer ??
            a.attributes?.value ?? null;
          if (raw !== null && raw !== undefined) {
            answers[qRel.id] = normalizeAnswer(raw);
          } else {
            // if it's a choice, try to resolve the included choice name
            const cRel = a.relationships?.choice?.data;
            if (cRel?.id) {
              const inc = included.get(`${cRel.type}:${cRel.id}`);
              if (inc?.attributes?.name) answers[qRel.id] = inc.attributes.name;
            }
          }
        }
        diag.push({ step: "answers-request", found: Object.keys(answers).length });
      } catch (e) {
        diag.push({ step: "answers-request-error", error: String(e) });
      }
    }

    // 3) FALLBACK: answers from event resource bookings, filtered to the specific resource
    if (Object.keys(answers).length === 0) {
      try {
        const bUrl =
          `https://api.planningcenteronline.com/calendar/v2/events/${event_id}/resource_bookings` +
          `?where[resource_id]=${encodeURIComponent(resource_id)}` +
          `&per_page=100` +
          `&include=resource,` +
          `resource_question_answers.resource_question,` +
          `resource_question_answers.choice`;
        const bJson = await pcoGet(bUrl);
        const included = new Map((bJson.included || []).map(x => [`${x.type}:${x.id}`, x]));
        const rqa = (bJson.included || []).filter(x => x.type === "ResourceQuestionAnswer");

        for (const a of rqa) {
          const qRel = a.relationships?.resource_question?.data;
          if (!qRel?.id) continue;
          const raw =
            a.attributes?.answer_text ??
            a.attributes?.answer_number ??
            a.attributes?.answer_boolean ??
            a.attributes?.answer_choice ??
            a.attributes?.answer ??
            a.attributes?.value ?? null;
          if (raw !== null && raw !== undefined) {
            answers[qRel.id] = normalizeAnswer(raw);
          } else {
            const cRel = a.relationships?.choice?.data;
            if (cRel?.id) {
              const inc = included.get(`${cRel.type}:${cRel.id}`);
              if (inc?.attributes?.name) answers[qRel.id] = inc.attributes.name;
            }
          }
        }
        diag.push({ step: "answers-bookings-fallback", found: Object.keys(answers).length });
      } catch (e) {
        diag.push({ step: "answers-bookings-error", error: String(e) });
      }
    }

    // 4) Event summary (optional)
    let event = null;
    try {
      const eJson = await pcoGet(`https://api.planningcenteronline.com/calendar/v2/events/${event_id}`);
      event = {
        id: eJson.data?.id,
        name: eJson.data?.attributes?.name,
        starts_at: eJson.data?.attributes?.starts_at,
        ends_at: eJson.data?.attributes?.ends_at,
        percent_approved: eJson.data?.attributes?.percent_approved,
        approval_status: eJson.data?.attributes?.approval_status
      };
    } catch (e) {
      diag.push({ step: "event-error", error: String(e) });
    }

    return Response.json({
      ok: true,
      event,
      questions,
      answers,
      totals: { questions: questions.length, answers: Object.keys(answers).length },
      diag
    });

  } catch (err) {
    return Response.json({ ok: false, error: String(err) }, { status: 500 });
  }
});
