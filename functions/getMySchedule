import { createClientFromRequest } from 'npm:@base44/sdk@0.7.1';

async function refreshTokenIfNeeded(base44, user) {
    const expiresAt = new Date(user.pco_token_expires_at);
    const fiveMinutesFromNow = new Date(Date.now() + 5 * 60 * 1000);

    if (expiresAt > fiveMinutesFromNow) {
        return user.pco_access_token;
    }

    const tokenResponse = await fetch('https://api.planningcenteronline.com/oauth/token', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams({
            grant_type: 'refresh_token',
            refresh_token: user.pco_refresh_token,
            client_id: Deno.env.get('PCO_CLIENT_ID'),
            client_secret: Deno.env.get('PCO_CLIENT_SECRET')
        })
    });

    if (!tokenResponse.ok) throw new Error('Token refresh failed');

    const tokens = await tokenResponse.json();
    const newExpiresAt = new Date(Date.now() + (tokens.expires_in * 1000)).toISOString();

    await base44.asServiceRole.entities.User.update(user.id, {
        pco_access_token: tokens.access_token,
        pco_refresh_token: tokens.refresh_token,
        pco_token_expires_at: newExpiresAt
    });

    return tokens.access_token;
}

Deno.serve(async (req) => {
    try {
        const base44 = createClientFromRequest(req);
        const currentUser = await base44.auth.me();

        if (!currentUser) {
            console.error('❌ No current user');
            return Response.json({ error: 'Unauthorized', events: [] }, { status: 401 });
        }

        console.log('✅ Getting schedule for:', currentUser.email);

        const users = await base44.asServiceRole.entities.User.filter({ email: currentUser.email });
        const user = users[0];

        if (!user || !user.pco_access_token) {
            console.log('❌ No PCO token');
            return Response.json({ events: [], message: 'PCO not connected' });
        }

        const accessToken = await refreshTokenIfNeeded(base44, user);

        // Get all events (getPCOCalendarEvents does this already)
        const allEventsResponse = await base44.asServiceRole.functions.invoke('getPCOCalendarEvents');
        const allEvents = allEventsResponse.data?.events || [];

        console.log('📅 Got', allEvents.length, 'total calendar events');

        // Now filter to events that require building access (have resources from Building Access group)
        const buildingAccessEvents = [];
        
        for (const event of allEvents) {
            // Check if any of the resources are from Building Access group
            const hasBuildingAccessResource = event.resources?.some(resource => {
                // You can identify building access resources by name or kind
                // Common patterns: room names, building names, doors, etc.
                const resourceName = resource.name?.toLowerCase() || '';
                return resourceName.includes('door') || 
                       resourceName.includes('room') || 
                       resourceName.includes('building') ||
                       resourceName.includes('access') ||
                       resourceName.includes('key');
            });

            if (hasBuildingAccessResource) {
                buildingAccessEvents.push(event);
            }
        }

        console.log('🚪 Found', buildingAccessEvents.length, 'events requiring building access');

        // Sort by start date
        buildingAccessEvents.sort((a, b) => 
            new Date(a.starts_at) - new Date(b.starts_at)
        );

        console.log('🎯 Returning', buildingAccessEvents.length, 'events');

        return Response.json({
            events: buildingAccessEvents,
            count: buildingAccessEvents.length
        });

    } catch (error) {
        console.error('❌ Get my schedule error:', error);
        console.error('❌ Error stack:', error.stack);
        return Response.json({
            error: error.message,
            events: [],
            details: error.stack
        }, { status: 500 });
    }
});