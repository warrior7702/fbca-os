import { createClientFromRequest } from 'npm:@base44/sdk@0.7.1';

async function refreshTokenIfNeeded(base44, user) {
    const expiresAt = new Date(user.pco_token_expires_at);
    const fiveMinutesFromNow = new Date(Date.now() + 5 * 60 * 1000);

    if (expiresAt > fiveMinutesFromNow) {
        return user.pco_access_token;
    }

    const tokenResponse = await fetch('https://api.planningcenteronline.com/oauth/token', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams({
            grant_type: 'refresh_token',
            refresh_token: user.pco_refresh_token,
            client_id: Deno.env.get('PCO_CLIENT_ID'),
            client_secret: Deno.env.get('PCO_CLIENT_SECRET')
        })
    });

    if (!tokenResponse.ok) throw new Error('Token refresh failed');

    const tokens = await tokenResponse.json();
    const newExpiresAt = new Date(Date.now() + (tokens.expires_in * 1000)).toISOString();

    await base44.asServiceRole.entities.User.update(user.id, {
        pco_access_token: tokens.access_token,
        pco_refresh_token: tokens.refresh_token,
        pco_token_expires_at: newExpiresAt
    });

    return tokens.access_token;
}

Deno.serve(async (req) => {
    try {
        const base44 = createClientFromRequest(req);
        const currentUser = await base44.auth.me();

        if (!currentUser) {
            console.error('❌ No current user');
            return Response.json({ error: 'Unauthorized', events: [] }, { status: 401 });
        }

        console.log('✅ Getting schedule for:', currentUser.email);

        const users = await base44.asServiceRole.entities.User.filter({ email: currentUser.email });
        const user = users[0];

        if (!user || !user.pco_access_token) {
            console.log('❌ No PCO token');
            return Response.json({ events: [], message: 'PCO not connected' });
        }

        const accessToken = await refreshTokenIfNeeded(base44, user);

        // STEP 1: Get my PCO person ID
        console.log('📞 Step 1: Getting my PCO person ID...');
        const meResponse = await fetch('https://api.planningcenteronline.com/people/v2/me', {
            headers: { 'Authorization': `Bearer ${accessToken}` }
        });

        if (!meResponse.ok) {
            throw new Error('Failed to get PCO person ID');
        }
        
        const meData = await meResponse.json();
        const myPersonId = meData.data?.id;
        console.log('👤 My PCO Person ID:', myPersonId);

        if (!myPersonId) {
            return Response.json({ 
                events: [], 
                message: 'Could not determine your PCO person ID'
            });
        }

        // STEP 2: Get ALL approval groups and check membership
        console.log('📞 Step 2: Getting approval groups...');
        const groupsResponse = await fetch(
            'https://api.planningcenteronline.com/calendar/v2/resource_approval_groups?per_page=100',
            { headers: { 'Authorization': `Bearer ${accessToken}` } }
        );

        if (!groupsResponse.ok) {
            throw new Error('Failed to fetch approval groups');
        }

        const groupsData = await groupsResponse.json();
        const myGroupIds = [];
        const resourceToGroup = {};

        console.log('📋 Found', (groupsData.data || []).length, 'total approval groups');

        // Check each group for membership
        for (const group of (groupsData.data || [])) {
            // Get group members
            const membersResponse = await fetch(
                `https://api.planningcenteronline.com/calendar/v2/resource_approval_groups/${group.id}/people?per_page=100`,
                { headers: { 'Authorization': `Bearer ${accessToken}` } }
            );
            
            if (membersResponse.ok) {
                const membersData = await membersResponse.json();
                const isMember = (membersData.data || []).some(person => person.id === myPersonId);
                
                if (isMember) {
                    myGroupIds.push(group.id);
                    console.log('✅ Member of group:', group.attributes?.name);
                }
            }

            // Get group resources (for filtering later)
            const resourcesResponse = await fetch(
                `https://api.planningcenteronline.com/calendar/v2/resource_approval_groups/${group.id}/resources?per_page=100`,
                { headers: { 'Authorization': `Bearer ${accessToken}` } }
            );

            if (resourcesResponse.ok) {
                const resourcesData = await resourcesResponse.json();
                for (const resource of (resourcesData.data || [])) {
                    resourceToGroup[resource.id] = {
                        groupId: group.id,
                        groupName: group.attributes?.name
                    };
                }
            }
        }

        console.log('📋 I am in', myGroupIds.length, 'approval groups');

        if (myGroupIds.length === 0) {
            return Response.json({ 
                events: [], 
                message: 'You are not in any approval groups'
            });
        }

        // STEP 3: Get event resource requests (Pending or Approved)
        console.log('📞 Step 3: Fetching resource requests...');
        
        const requestsUrl = 'https://api.planningcenteronline.com/calendar/v2/event_resource_requests?where[approval_status]=P,A&include=event,resource&per_page=100';
        
        const requestsResponse = await fetch(requestsUrl, {
            headers: { 'Authorization': `Bearer ${accessToken}` }
        });

        if (!requestsResponse.ok) {
            const errorText = await requestsResponse.text();
            console.error('❌ Requests fetch failed:', errorText);
            throw new Error('Failed to fetch resource requests');
        }

        const requestsData = await requestsResponse.json();
        console.log('📊 Fetched', (requestsData.data || []).length, 'resource requests');

        // Build maps for events and resources from included data
        const eventsMap = {};
        const resourcesMap = {};

        if (requestsData.included) {
            for (const item of requestsData.included) {
                if (item.type === 'Event') {
                    eventsMap[item.id] = {
                        id: item.id,
                        name: item.attributes?.name,
                        summary: item.attributes?.summary
                    };
                } else if (item.type === 'Resource') {
                    resourcesMap[item.id] = {
                        id: item.id,
                        name: item.attributes?.name,
                        kind: item.attributes?.kind
                    };
                }
            }
        }

        // Filter requests to MY groups only
        const myRequests = (requestsData.data || []).filter(request => {
            const resourceId = request.relationships?.resource?.data?.id;
            const groupInfo = resourceToGroup[resourceId];
            return groupInfo && myGroupIds.includes(groupInfo.groupId);
        });

        console.log('📋 Found', myRequests.length, 'requests for my groups');

        // Get event IDs we care about
        const eventIds = new Set();
        myRequests.forEach(req => {
            const eventId = req.relationships?.event?.data?.id;
            if (eventId) eventIds.add(eventId);
        });

        console.log('📊 Unique events:', eventIds.size);

        // STEP 4: Fetch FUTURE event instances (simple query)
        console.log('📞 Step 4: Fetching event instances (next 2 weeks)...');
        
        // Use simple filter=future without date filters
        const instancesUrl = 'https://api.planningcenteronline.com/calendar/v2/event_instances?filter=future&order=starts_at&per_page=100';
        
        const instancesResponse = await fetch(instancesUrl, {
            headers: { 'Authorization': `Bearer ${accessToken}` }
        });

        if (!instancesResponse.ok) {
            const errorText = await instancesResponse.text();
            console.error('❌ Event instances fetch failed:', instancesResponse.status, errorText);
            throw new Error('Failed to fetch event instances: ' + instancesResponse.status);
        }

        const instancesData = await instancesResponse.json();
        const instances = instancesData.data || [];
        
        console.log('📅 Found', instances.length, 'future event instances');

        // Filter to 2-week window and matching events on our side
        const now = new Date();
        const twoWeeksFromNow = new Date(now);
        twoWeeksFromNow.setDate(twoWeeksFromNow.getDate() + 14);

        // Build final events array
        const eventsWithMyResources = [];

        for (const instance of instances) {
            const eventId = instance.relationships?.event?.data?.id;
            const startsAt = instance.attributes?.starts_at;
            
            if (!startsAt) continue;
            
            const startDate = new Date(startsAt);
            
            // Filter to 2-week window
            if (startDate > twoWeeksFromNow) continue;
            
            // Check if this event has any of my group's resource requests
            const eventRequests = myRequests.filter(req => 
                req.relationships?.event?.data?.id === eventId
            );

            if (eventRequests.length === 0) continue;

            const event = eventsMap[eventId];
            if (!event || !event.name || event.name === 'Untitled Event') continue;

            const resources = eventRequests.map(req => {
                const resourceId = req.relationships?.resource?.data?.id;
                const resource = resourcesMap[resourceId];
                return {
                    id: resourceId,
                    name: resource?.name || 'Unknown Resource',
                    kind: resource?.kind,
                    approval_status: req.attributes?.approval_status // 'P' or 'A'
                };
            });

            eventsWithMyResources.push({
                id: instance.id,
                event_id: eventId,
                name: event.name,
                starts_at: instance.attributes?.starts_at,
                ends_at: instance.attributes?.ends_at,
                summary: event.summary,
                resources: resources
            });
        }

        // Sort by start date
        eventsWithMyResources.sort((a, b) => 
            new Date(a.starts_at) - new Date(b.starts_at)
        );

        console.log('🎯 Returning', eventsWithMyResources.length, 'events');
        
        if (eventsWithMyResources.length > 0) {
            console.log('📋 Sample events:');
            eventsWithMyResources.slice(0, 3).forEach(event => {
                const pendingCount = event.resources.filter(r => r.approval_status === 'P').length;
                const approvedCount = event.resources.filter(r => r.approval_status === 'A').length;
                console.log(`  - ${event.name} (${new Date(event.starts_at).toLocaleDateString()}) - ${pendingCount} pending, ${approvedCount} approved`);
            });
        }

        return Response.json({
            events: eventsWithMyResources,
            count: eventsWithMyResources.length,
            my_groups_count: myGroupIds.length
        });

    } catch (error) {
        console.error('❌ Get my schedule error:', error);
        console.error('❌ Error stack:', error.stack);
        return Response.json({
            error: error.message,
            events: [],
            details: error.stack
        }, { status: 500 });
    }
});