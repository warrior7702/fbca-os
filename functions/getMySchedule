import { createClientFromRequest } from 'npm:@base44/sdk@0.7.1';

Deno.serve(async (req) => {
    try {
        const base44 = createClientFromRequest(req);
        const currentUser = await base44.auth.me();

        if (!currentUser) {
            console.error('❌ No current user');
            return Response.json({ error: 'Unauthorized', events: [] }, { status: 401 });
        }

        const email = currentUser.email;
        console.log('✅ Getting schedule for:', email);

        // Call the Vercel endpoint that uses service token and better logic
        const vercelUrl = `https://pco-webhook.vercel.app/api/my-schedule?email=${encodeURIComponent(email)}&days=14`;
        
        console.log('📞 Calling Vercel endpoint:', vercelUrl);
        
        const response = await fetch(vercelUrl, {
            method: 'GET',
            headers: {
                'Accept': 'application/json'
            }
        });

        if (!response.ok) {
            const errorText = await response.text();
            console.error('❌ Vercel endpoint failed:', response.status, errorText);
            return Response.json({ 
                error: `Vercel endpoint failed: ${response.status}`,
                events: [],
                details: errorText
            }, { status: response.status });
        }

        const data = await response.json();
        
        console.log('✅ Vercel response:', {
            ok: data.ok,
            count: data.count,
            person: data.person
        });

        if (!data.ok) {
            console.error('❌ Vercel returned error:', data.error);
            return Response.json({
                error: data.error,
                events: [],
                details: data
            }, { status: 400 });
        }

        // Transform the data format to match what the frontend expects
        const events = (data.events || []).map(event => ({
            id: event.event_id,
            event_id: event.event_id,
            name: event.event_name,
            starts_at: event.starts_at,
            ends_at: event.ends_at,
            summary: '',
            resources: event.requests.map(req => ({
                id: req.resource_id,
                name: req.resource_name,
                approval_status: req.approval_status // 'P' or 'A'
            }))
        }));

        console.log('🎯 Returning', events.length, 'events');
        
        if (events.length > 0) {
            console.log('📋 Sample events:');
            events.slice(0, 3).forEach(event => {
                const pendingCount = event.resources.filter(r => r.approval_status === 'P').length;
                const approvedCount = event.resources.filter(r => r.approval_status === 'A').length;
                console.log(`  - ${event.name} (${new Date(event.starts_at).toLocaleDateString()}) - ${pendingCount} pending, ${approvedCount} approved`);
            });
        }

        return Response.json({
            events: events,
            count: events.length,
            person: data.person,
            range: data.range
        });

    } catch (error) {
        console.error('❌ Get my schedule error:', error);
        console.error('❌ Error stack:', error.stack);
        return Response.json({
            error: error.message,
            events: [],
            details: error.stack
        }, { status: 500 });
    }
});