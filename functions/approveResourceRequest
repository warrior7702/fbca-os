// functions/approveResourceRequest.js  (Base44 — Deno)
import { createClientFromRequest } from "npm:@base44/sdk@0.7.1";

// --- helpers ---------------------------------------------------
async function pcoJson(url, token, init = {}) {
  const r = await fetch(url, {
    ...init,
    headers: {
      Authorization: `Bearer ${token}`,
      "Content-Type": "application/json",
      ...(init.headers || {}),
    },
  });
  const raw = await r.text();
  let json = {};
  try { json = raw ? JSON.parse(raw) : {}; } catch {}
  if (!r.ok) throw new Error(`HTTP ${r.status} :: ${url} :: ${raw.slice(0,800)}`);
  return json;
}

async function useServiceToken() {
  const cid = Deno.env.get("PCO_CLIENT_ID");
  const cs  = Deno.env.get("PCO_CLIENT_SECRET");
  const rt  = Deno.env.get("PCO_SERVICE_REFRESH_TOKEN"); // calendar admin refresher
  if (!cid || !cs || !rt) return null;

  const res = await fetch("https://api.planningcenteronline.com/oauth/token", {
    method: "POST",
    headers: { "Content-Type": "application/x-www-form-urlencoded" },
    body: new URLSearchParams({
      grant_type: "refresh_token",
      client_id: cid,
      client_secret: cs,
      refresh_token: rt,
    }),
  });
  const j = await res.json();
  if (!res.ok || !j.access_token) return null;
  return j.access_token;
}

// --- main ------------------------------------------------------
Deno.serve(async (req) => {
  try {
    const b44 = createClientFromRequest(req);
    const me  = await b44.auth.me(); // ← carries user.pco_access_token
    const { request_id, action = "approve", note = "" } = await req.json();

    if (!request_id || !["approve","deny"].includes(action)) {
      return Response.json({ ok:false, error:"request_id and action=approve|deny required" }, { status:400 });
    }
    if (!me?.pco_access_token) {
      return Response.json({ ok:false, error:"User is not connected to PCO" }, { status:401 });
    }

    const userToken = me.pco_access_token;

    // 1) who am I (People scope)
    const mePeople = await pcoJson("https://api.planningcenteronline.com/people/v2/me", userToken);
    const personId = mePeople?.data?.id;
    const personName = mePeople?.data?.attributes?.name;

    // 2) pull the request (approval group, status, event name)
    const reqUrl = `https://api.planningcenteronline.com/calendar/v2/event_resource_requests/${request_id}?include=approval_group,event,assigned_to_person`;
    const reqData = await pcoJson(reqUrl, userToken);
    const status  = reqData?.data?.attributes?.approval_status; // "P"
    const groupId = reqData?.data?.relationships?.approval_group?.data?.id || null;
    const eventName = (reqData?.included || []).find(x => x.type==="Event")?.attributes?.name || null;

    if (status !== "P") {
      return Response.json({ ok:false, error:`Request is not pending (status=${status})` }, { status:409 });
    }

    // 3) check group membership (if org uses it)
    let inGroup = true;
    try {
      const mem = await pcoJson(
        `https://api.planningcenteronline.com/calendar/v2/resource_approval_group_memberships` +
        `?where[person_id]=${personId}&per_page=200&include=resource_approval_group`,
        userToken
      );
      const ids = (mem.data || []).map(d => d?.relationships?.resource_approval_group?.data?.id).filter(Boolean);
      if (groupId) inGroup = ids.includes(groupId);
    } catch {
      // ignore — some orgs don't use memberships; treat as allowed
      inGroup = true;
    }

    // 4) perform action with the **user** token if allowed
    const endpoint = `https://api.planningcenteronline.com/calendar/v2/event_resource_requests/${request_id}/${action}`;
    const body = JSON.stringify(note ? { note } : {});

    async function postWith(token, who) {
      const r = await fetch(endpoint, { method:"POST", headers:{ Authorization:`Bearer ${token}`, "Content-Type":"application/json" }, body });
      const txt = await r.text();
      return { ok:r.ok, status:r.status, txt, who };
    }

    if (inGroup) {
      const r = await postWith(userToken, "user");
      if (r.ok) return Response.json({ ok:true, by:"user", personId, personName, eventName, action });
      // fall through to optional service fallback if configured
    }

    // 5) optional service fallback (Calendar Admin)
    const allowService = (Deno.env.get("ALLOW_SERVICE_APPROVALS") || "false").toLowerCase() === "true";
    if (!allowService) {
      return Response.json({
        ok:false,
        error:"Forbidden (not in approval group)",
        diag:{ personId, personName, eventName, groupId, inGroup }
      }, { status:403 });
    }

    const svcToken = await useServiceToken();
    if (!svcToken) {
      return Response.json({ ok:false, error:"Service token not available" }, { status:500 });
    }

    // tag the note for audit
    const auditNote = note
      ? `${note} — (via Base44 by ${personName})`
      : `Approved via Base44 by ${personName}`;
    const r2 = await fetch(endpoint, {
      method:"POST",
      headers:{ Authorization:`Bearer ${svcToken}`, "Content-Type":"application/json" },
      body: JSON.stringify({ note: auditNote })
    });
    const txt2 = await r2.text();
    if (!r2.ok) {
      return Response.json({ ok:false, error:`PCO ${action} failed`, status:r2.status, body:txt2 }, { status:r2.status });
    }

    return Response.json({ ok:true, by:"service", personId, personName, eventName, action });

  } catch (e) {
    return Response.json({ ok:false, error:String(e) }, { status:500 });
  }
});