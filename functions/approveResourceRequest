// approveResourceRequest.js  (Base44 Deno runtime)
import { createClientFromRequest } from 'npm:@base44/sdk@0.7.1';

const PCO = {
  base: 'https://api.planningcenteronline.com/calendar/v2'
};

async function pcoGet(url, token) {
  const r = await fetch(url, { headers: { Authorization: `Bearer ${token}` } });
  const j = await r.json().catch(() => ({}));
  if (!r.ok) throw new Error(`GET ${url} :: ${r.status} :: ${JSON.stringify(j)}`);
  return j;
}

async function pcoPatch(url, token, body = {}) {
  const r = await fetch(url, {
    method: 'PATCH',
    headers: {
      Authorization: `Bearer ${token}`,
      'Content-Type': 'application/json'
    },
    body: JSON.stringify(body)
  });
  const text = await r.text();
  if (!r.ok) throw new Error(`PATCH ${url} :: ${r.status} :: ${text}`);
  return text ? JSON.parse(text) : { ok: true };
}

Deno.serve(async (req) => {
  const debugInfo = {}; // Collect debug info throughout the process
  
  try {
    const base44 = createClientFromRequest(req);
    const me = await base44.auth.me();

    // ---- 0) parse payload safely (support JSON or form POST) ----
    let body = {};
    const ct = req.headers.get('content-type') || '';
    if (ct.includes('application/json')) {
      try { body = await req.json(); } catch { body = {}; }
    } else if (ct.includes('application/x-www-form-urlencoded')) {
      const form = await req.formData();
      body = Object.fromEntries(form.entries());
    }
    const request_id = String(body.request_id || '').trim();
    const action = String(body.action || '').trim().toLowerCase(); // 'approve' | 'deny'
    const note = body.note ? String(body.note) : undefined;

    debugInfo.request_id = request_id;
    debugInfo.action = action;

    if (!request_id || !['approve', 'deny'].includes(action)) {
      return Response.json(
        { ok: false, error: 'request_id and action=approve|deny required', debug: debugInfo },
        { status: 400 }
      );
    }

    // ---- 1) require a user token; don't use the service token for writes ----
    const userToken = me?.pco_access_token;
    const storedCalendarUserId = me?.pco_user_id;
    
    debugInfo.user_email = me?.email;
    debugInfo.stored_calendar_user_id = storedCalendarUserId;
    
    if (!userToken) {
      return Response.json(
        { ok: false, error: 'No PCO token. Please reconnect PCO in Settings.', debug: debugInfo },
        { status: 401 }
      );
    }

    console.log('🔍 ========== PCO USER IDENTITY DISCOVERY ==========');
    console.log('📧 Base44 Email:', me.email);
    console.log('💾 Stored Calendar User ID:', storedCalendarUserId);

    // DISCOVERY: Get ALL possible user IDs from different PCO APIs
    const userIdentities = {
      email: me.email,
      stored_id: storedCalendarUserId
    };

    // 1. Calendar /me
    try {
      const calendarMeResponse = await pcoGet('https://api.planningcenteronline.com/calendar/v2/me', userToken);
      userIdentities.calendar_me_id = calendarMeResponse.data?.id;
      userIdentities.calendar_me_name = calendarMeResponse.data?.attributes?.name;
      userIdentities.calendar_me_email = calendarMeResponse.data?.attributes?.email;
      console.log('📅 Calendar /me ID:', userIdentities.calendar_me_id);
      console.log('   Name:', userIdentities.calendar_me_name);
      console.log('   Email:', userIdentities.calendar_me_email);
    } catch (e) {
      console.log('❌ Calendar /me failed:', e.message);
    }

    // 2. People /me
    try {
      const peopleMeResponse = await pcoGet('https://api.planningcenteronline.com/people/v2/me', userToken);
      userIdentities.people_me_id = peopleMeResponse.data?.id;
      userIdentities.people_me_name = peopleMeResponse.data?.attributes?.name;
      userIdentities.people_me_email = peopleMeResponse.data?.attributes?.primary_campus_id;
      console.log('👤 People /me ID:', userIdentities.people_me_id);
      console.log('   Name:', userIdentities.people_me_name);
    } catch (e) {
      console.log('❌ People /me failed:', e.message);
    }

    // 3. Token introspection (who owns this token?)
    try {
      const tokenResponse = await fetch('https://api.planningcenteronline.com/people/v2/me', {
        headers: { 'Authorization': `Bearer ${userToken}` }
      });
      if (tokenResponse.ok) {
        const tokenData = await tokenResponse.json();
        userIdentities.token_owner_id = tokenData.data?.id;
        userIdentities.token_owner_name = tokenData.data?.attributes?.name;
        console.log('🔑 Token Owner ID (from People):', userIdentities.token_owner_id);
        console.log('   Name:', userIdentities.token_owner_name);
      }
    } catch (e) {
      console.log('❌ Token introspection failed:', e.message);
    }

    // 4. Try to get the Calendar user for the People person
    if (userIdentities.people_me_id) {
      try {
        // Search for Calendar users by email
        const searchUrl = `https://api.planningcenteronline.com/calendar/v2/people?where[email]=${encodeURIComponent(me.email)}`;
        const searchResponse = await pcoGet(searchUrl, userToken);
        if (searchResponse.data && searchResponse.data.length > 0) {
          userIdentities.calendar_user_from_email = searchResponse.data[0].id;
          console.log('🔍 Calendar User ID (from email search):', userIdentities.calendar_user_from_email);
        }
      } catch (e) {
        console.log('❌ Calendar user search failed:', e.message);
      }
    }

    debugInfo.all_identities = userIdentities;
    
    console.log('📊 ========== IDENTITY SUMMARY ==========');
    console.log(JSON.stringify(userIdentities, null, 2));
    console.log('=========================================');

    // Determine which Calendar User ID to use
    const calendarUserId = userIdentities.calendar_me_id || storedCalendarUserId;
    
    if (!calendarUserId) {
      return Response.json(
        { 
          ok: false, 
          error: 'Could not determine Calendar User ID. Please reconnect PCO in Settings.',
          debug: debugInfo,
          identities: userIdentities
        },
        { status: 401 }
      );
    }

    console.log('✅ Using Calendar User ID for approval:', calendarUserId);
    debugInfo.calendar_user_id_used = calendarUserId;

    // ---- 2) Get request details first (1 API call) ----
    console.log('📦 Step 1: Fetching request details for request ID:', request_id);
    
    const requestResponse = await pcoGet(
      `${PCO.base}/event_resource_requests/${request_id}?include=resource`,
      userToken
    );

    const resourceId = requestResponse.data?.relationships?.resource?.data?.id;
    const resourceData = requestResponse.included?.find(i => i.type === 'Resource' && i.id === resourceId);
    const resourceName = resourceData?.attributes?.name;
    
    debugInfo.resource_id = resourceId;
    debugInfo.resource_name = resourceName;
    
    console.log('📦 Request is for resource:', resourceName, '(ID:', resourceId, ')');

    // ---- 3) Get approval groups for THIS resource only (1 API call) ----
    console.log('👥 Step 2: Finding approval groups for this resource...');
    
    const resourceGroupsResponse = await pcoGet(
      `${PCO.base}/resources/${resourceId}/resource_approval_groups?per_page=100`,
      userToken
    );

    const approvalGroups = resourceGroupsResponse.data || [];
    debugInfo.total_approval_groups_for_resource = approvalGroups.length;
    
    console.log('📋 Found', approvalGroups.length, 'approval groups that manage this resource');

    if (approvalGroups.length === 0) {
      console.log('❌ No approval groups manage this resource');
      return Response.json({
        ok: false,
        error: 'No approval groups manage this resource',
        debug: debugInfo,
        identities: userIdentities
      }, { status: 403 });
    }

    // ---- 4) Check membership in ONLY these groups - TRY ALL KNOWN IDS ----
    console.log('🔐 Step 3: Checking membership in approval groups...');
    console.log('   Will try these IDs:', [calendarUserId, userIdentities.calendar_user_from_email, userIdentities.people_me_id].filter(Boolean));
    
    let hasPermission = false;
    let matchingGroupName = null;
    let matchedWithId = null;
    const checkedGroups = [];
    
    for (const group of approvalGroups) {
      console.log('👥 Checking membership in group:', group.attributes?.name, '(ID:', group.id, ')');
      
      // Use CALENDAR API people endpoint for this group
      const membersResponse = await pcoGet(
        `${PCO.base}/resource_approval_groups/${group.id}/people?per_page=100`,
        userToken
      );
      
      const members = membersResponse.data || [];
      console.log('   └─ Group has', members.length, 'members');
      
      // Log all member IDs for comparison
      const memberIds = members.map(m => m.id);
      console.log('   └─ Member IDs:', memberIds.slice(0, 10).join(', '), memberIds.length > 10 ? '...' : '');
      
      // Try matching with ANY of our known IDs
      const possibleIds = [
        calendarUserId,
        userIdentities.calendar_user_from_email,
        userIdentities.people_me_id,
        userIdentities.token_owner_id
      ].filter(Boolean);
      
      let matchedId = null;
      for (const tryId of possibleIds) {
        if (memberIds.includes(tryId)) {
          matchedId = tryId;
          console.log('   └─ ✅ MATCH! Found ID', tryId, 'in group members');
          break;
        }
      }
      
      const isMember = matchedId !== null;
      
      checkedGroups.push({
        group_id: group.id,
        group_name: group.attributes?.name,
        is_member: isMember,
        member_count: members.length,
        matched_id: matchedId
      });
      
      if (isMember) {
        hasPermission = true;
        matchingGroupName = group.attributes?.name;
        matchedWithId = matchedId;
        console.log('✅ PERMISSION GRANTED! Matched with ID:', matchedId, 'in group:', matchingGroupName);
        break;
      } else {
        console.log('❌ None of our IDs found in this group');
      }
    }

    debugInfo.checked_groups = checkedGroups;
    debugInfo.has_permission = hasPermission;
    debugInfo.matching_group_name = matchingGroupName;
    debugInfo.matched_with_id = matchedWithId;

    console.log('🔐 FINAL PERMISSION CHECK:', hasPermission ? '✅ GRANTED' : '❌ DENIED');

    if (!hasPermission) {
      console.log('❌ PERMISSION DENIED');
      console.log('📊 Tried these IDs:');
      console.log('   - Calendar User ID:', calendarUserId);
      console.log('   - Calendar from email:', userIdentities.calendar_user_from_email);
      console.log('   - People ID:', userIdentities.people_me_id);
      console.log('   - Token Owner:', userIdentities.token_owner_id);
      
      return Response.json({
        ok: false,
        error: 'You are not authorized to approve this resource',
        debug: debugInfo,
        identities: userIdentities,
        diagnostic_message: `None of your PCO user IDs are members of approval groups for "${resourceName}". Please check the group membership in PCO.`
      }, { status: 403 });
    }

    // ---- 5) PATCH the request to approve/deny ----
    const statusCode = action === 'approve' ? 'A' : 'R'; // A=Approved, R=Rejected
    const url = `${PCO.base}/event_resource_requests/${request_id}`;
    
    console.log('🚀 Step 4: Patching PCO request:', url);
    console.log('  Status:', statusCode);
    
    const patchBody = {
      data: {
        type: 'EventResourceRequest',
        id: request_id,
        attributes: {
          approval_status: statusCode
        }
      }
    };

    // Add note if provided
    if (note) {
      patchBody.data.attributes.notes = note;
    }

    const result = await pcoPatch(url, userToken, patchBody);

    console.log('✅ PCO request', action === 'approve' ? 'approved' : 'denied', 'successfully');

    return Response.json({ 
      ok: true, 
      action, 
      request_id, 
      result,
      matched_with_id: matchedWithId,
      debug: debugInfo,
      identities: userIdentities
    });
  } catch (e) {
    console.error('❌ Approve error:', e);
    debugInfo.error = e.message;
    debugInfo.stack = e.stack;
    return Response.json({ 
      ok: false, 
      error: String(e),
      debug: debugInfo
    }, { status: 500 });
  }
});