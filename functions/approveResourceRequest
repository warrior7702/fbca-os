// approveResourceRequest.js  (Base44 Deno runtime)
import { createClientFromRequest } from 'npm:@base44/sdk@0.7.1';

const PCO = {
  base: 'https://api.planningcenteronline.com/calendar/v2'
};

async function refreshTokenIfNeeded(base44, user) {
  try {
    const expiresAt = new Date(user.pco_token_expires_at);
    const fiveMinutesFromNow = new Date(Date.now() + 5 * 60 * 1000);

    if (expiresAt > fiveMinutesFromNow) {
      return user.pco_access_token;
    }

    console.log('🔄 Refreshing token...');

    const tokenResponse = await fetch('https://api.planningcenteronline.com/oauth/token', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams({
        grant_type: 'refresh_token',
        refresh_token: user.pco_refresh_token,
        client_id: Deno.env.get('PCO_CLIENT_ID'),
        client_secret: Deno.env.get('PCO_CLIENT_SECRET')
      })
    });

    if (!tokenResponse.ok) {
      throw new Error('Token refresh failed: ' + tokenResponse.status);
    }

    const tokens = await tokenResponse.json();
    const newExpiresAt = new Date(Date.now() + (tokens.expires_in * 1000)).toISOString();

    await base44.asServiceRole.entities.User.update(user.id, {
      pco_access_token: tokens.access_token,
      pco_refresh_token: tokens.refresh_token,
      pco_token_expires_at: newExpiresAt
    });

    console.log('✅ Token refreshed');
    return tokens.access_token;
  } catch (error) {
    console.error('❌ Token refresh error:', error);
    throw error;
  }
}

Deno.serve(async (req) => {
  let base44;
  let currentUser;
  
  try {
    base44 = createClientFromRequest(req);
    currentUser = await base44.auth.me();

    if (!currentUser) {
      return Response.json({ ok: false, error: 'Not authenticated' }, { status: 401 });
    }

    console.log('🔐 User:', currentUser.email);

    // Parse request body
    let body = {};
    const ct = req.headers.get('content-type') || '';
    if (ct.includes('application/json')) {
      try { body = await req.json(); } catch { body = {}; }
    } else if (ct.includes('application/x-www-form-urlencoded')) {
      const form = await req.formData();
      body = Object.fromEntries(form.entries());
    }

    const request_id = String(body.request_id || '').trim();
    const action = String(body.action || '').trim().toLowerCase();
    const note = body.note ? String(body.note) : undefined;

    if (!request_id) {
      return Response.json({ ok: false, error: 'request_id required' }, { status: 400 });
    }

    if (!['approve', 'deny'].includes(action)) {
      return Response.json({ ok: false, error: 'action must be "approve" or "deny"' }, { status: 400 });
    }

    console.log('📋 Action:', action, 'Request ID:', request_id);

    // Get full user record
    const users = await base44.asServiceRole.entities.User.filter({ 
      email: currentUser.email 
    });
    
    if (!users || users.length === 0) {
      return Response.json({ ok: false, error: 'User record not found' }, { status: 404 });
    }

    const user = users[0];

    if (!user.pco_access_token) {
      return Response.json({
        ok: false,
        error: 'PCO not connected. Connect in Settings.'
      }, { status: 401 });
    }

    // Get or refresh token
    const userToken = await refreshTokenIfNeeded(base44, user);
    console.log('✅ Got valid token');

    // Simple approach: Just try to approve it
    // If user doesn't have permission, PCO will return an error
    const statusCode = action === 'approve' ? 'A' : 'R';
    const url = `${PCO.base}/event_resource_requests/${request_id}`;
    
    console.log('🚀 Sending approval to PCO:', url);
    console.log('  Status code:', statusCode, '(A=Approved, R=Rejected)');
    
    const patchBody = {
      data: {
        type: 'EventResourceRequest',
        id: request_id,
        attributes: {
          approval_status: statusCode
        }
      }
    };

    if (note) {
      patchBody.data.attributes.notes = note;
    }

    const pcoResponse = await fetch(url, {
      method: 'PATCH',
      headers: {
        Authorization: `Bearer ${userToken}`,
        'Content-Type': 'application/json'
      },
      body: JSON.stringify(patchBody)
    });

    const responseText = await pcoResponse.text();
    
    if (!pcoResponse.ok) {
      console.error('❌ PCO API error:', pcoResponse.status);
      console.error('   Response:', responseText);
      
      // Parse error details if available
      let errorMessage = `PCO API error: ${pcoResponse.status}`;
      try {
        const errorData = JSON.parse(responseText);
        if (errorData.errors && errorData.errors.length > 0) {
          errorMessage = errorData.errors[0].detail || errorData.errors[0].title || errorMessage;
        }
      } catch (e) {
        // If we can't parse, use the raw text
        if (responseText) {
          errorMessage += ': ' + responseText.substring(0, 200);
        }
      }
      
      return Response.json({ 
        ok: false, 
        error: errorMessage,
        status: pcoResponse.status,
        details: responseText
      }, { status: 400 });
    }

    const result = responseText ? JSON.parse(responseText) : { ok: true };

    console.log('✅ Successfully', action === 'approve' ? 'approved' : 'denied', 'request in PCO');

    return Response.json({ 
      ok: true, 
      action, 
      request_id, 
      result 
    });

  } catch (error) {
    console.error('❌ Unexpected error:');
    console.error('  Message:', error.message);
    console.error('  Stack:', error.stack);
    
    return Response.json({ 
      ok: false, 
      error: 'Internal error: ' + error.message,
      details: error.stack
    }, { status: 500 });
  }
});