import { createClientFromRequest } from 'npm:@base44/sdk@0.7.1';

Deno.serve(async (req) => {
    try {
        const base44 = createClientFromRequest(req);
        const user = await base44.auth.me();

        if (!user) {
            return Response.json({ error: 'Unauthorized' }, { status: 401 });
        }

        if (!user.pco_access_token) {
            return Response.json({ 
                error: 'PCO not connected',
                who: user.email 
            }, { status: 400 });
        }

        const { request_id, action, note } = await req.json();

        if (!request_id || !['approve', 'deny'].includes(action)) {
            return Response.json({ 
                error: 'request_id and action=approve|deny required' 
            }, { status: 400 });
        }

        const token = user.pco_access_token;

        console.log('🔍 Starting approval process...');
        console.log('👤 User:', user.email);
        console.log('📋 Request ID:', request_id);
        console.log('⚡ Action:', action);

        // Get my Person ID from People API
        const meResponse = await fetch('https://api.planningcenteronline.com/people/v2/me', {
            headers: { 'Authorization': `Bearer ${token}` }
        });

        if (!meResponse.ok) {
            console.error('❌ Failed to get PCO user info');
            return Response.json({ 
                error: 'Failed to get PCO user info' 
            }, { status: 500 });
        }

        const meData = await meResponse.json();
        const myPersonId = meData?.data?.id;
        const myName = meData?.data?.attributes?.name;

        console.log('👤 I am:', myName, 'ID:', myPersonId);

        // Get the request details
        const requestUrl = `https://api.planningcenteronline.com/calendar/v2/event_resource_requests/${request_id}?include=approval_group,assigned_to_person`;
        const requestResponse = await fetch(requestUrl, {
            headers: { 'Authorization': `Bearer ${token}` }
        });

        if (!requestResponse.ok) {
            console.error('❌ Request not found');
            return Response.json({ 
                error: 'Request not found' 
            }, { status: 404 });
        }

        const requestData = await requestResponse.json();
        const request = requestData?.data;
        const status = request?.attributes?.approval_status;

        if (status !== 'P') {
            console.error('❌ Request not pending, status:', status);
            return Response.json({ 
                error: `Request not pending (status: ${status})` 
            }, { status: 409 });
        }

        const groupId = request?.relationships?.approval_group?.data?.id || null;
        const assignedId = request?.relationships?.assigned_to_person?.data?.id || null;

        console.log('📋 Group ID:', groupId || 'none');
        console.log('📋 Assigned to:', assignedId || 'none');

        // Check eligibility
        let eligible = false;

        if (groupId) {
            // Check group membership
            const memberUrl = `https://api.planningcenteronline.com/calendar/v2/resource_approval_group_memberships?where[person_id]=${myPersonId}&per_page=200`;
            const memberResponse = await fetch(memberUrl, {
                headers: { 'Authorization': `Bearer ${token}` }
            });

            if (memberResponse.ok) {
                const memberData = await memberResponse.json();
                const myGroups = (memberData?.data || [])
                    .map(m => m?.relationships?.resource_approval_group?.data?.id)
                    .filter(Boolean);

                eligible = myGroups.includes(groupId);
                console.log('✅ My groups:', myGroups);
                console.log('🔍 Am I eligible?', eligible);
            }
        } else {
            // No group - check if assigned to me
            eligible = !assignedId || assignedId === myPersonId;
            console.log('🔍 No group - assigned to me?', eligible);
        }

        if (!eligible) {
            console.error('❌ Not authorized');
            return Response.json({
                error: 'You are not authorized to approve/deny this request',
                personId: myPersonId,
                groupId: groupId || null,
                assignedId: assignedId || null
            }, { status: 403 });
        }

        // Approve or deny using the correct endpoint
        const endpoint = `https://api.planningcenteronline.com/calendar/v2/event_resource_requests/${request_id}/${action}`;
        const body = note ? { note } : {};

        console.log('✅ Eligible! Calling:', endpoint);

        const actionResponse = await fetch(endpoint, {
            method: 'POST',
            headers: {
                'Authorization': `Bearer ${token}`,
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(body)
        });

        const responseText = await actionResponse.text();

        if (!actionResponse.ok) {
            console.error('❌ PCO error:', actionResponse.status, responseText);
            return Response.json({ 
                error: `PCO ${action} failed`,
                status: actionResponse.status,
                details: responseText.slice(0, 500)
            }, { status: actionResponse.status });
        }

        console.log('✅ Success!');

        return Response.json({
            ok: true,
            action,
            request_id,
            personId: myPersonId,
            personName: myName
        });

    } catch (error) {
        console.error('❌ Error:', error);
        return Response.json({ 
            error: error.message 
        }, { status: 500 });
    }
});