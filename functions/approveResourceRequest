import { createClientFromRequest } from 'npm:@base44/sdk@0.7.1';

Deno.serve(async (req) => {
    try {
        console.log('🟢 Function started');
        
        const base44 = createClientFromRequest(req);
        const currentUser = await base44.auth.me();

        console.log('🟢 Current user:', currentUser?.email);

        if (!currentUser) {
            return Response.json({ error: 'Unauthorized' }, { status: 401 });
        }

        const body = await req.json();
        const { request_id } = body;

        console.log('🟢 Request body:', body);
        console.log('🟢 Request ID:', request_id);

        if (!request_id) {
            return Response.json({ error: 'Missing request_id' }, { status: 400 });
        }

        console.log('🔵 Starting approval process for request:', request_id);

        // Use the getPCOToken function to ensure we get the right token
        const tokenResponse = await base44.functions.invoke('getPCOToken');
        const accessToken = tokenResponse.data.access_token;
        const tokenUserId = tokenResponse.data.token_user_id;

        console.log('✅ Got PCO token for user ID:', tokenUserId);

        console.log('🔵 Token ready, making approval request...');

        // Approve the resource request in PCO
        const response = await fetch(
            `https://api.planningcenteronline.com/calendar/v2/event_resource_requests/${request_id}`,
            {
                method: 'PATCH',
                headers: {
                    'Authorization': `Bearer ${accessToken}`,
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    data: {
                        type: 'EventResourceRequest',
                        id: request_id,
                        attributes: {
                            approval_status: 'A'
                        }
                    }
                })
            }
        );

        console.log('🔵 PCO approval response status:', response.status);
        
        const responseText = await response.text();

        if (!response.ok) {
            console.error('❌ PCO approval failed:', responseText);
            return Response.json({ 
                error: 'Failed to approve in PCO',
                details: responseText,
                status: response.status,
                token_user_id: tokenUserId
            }, { status: 500 });
        }

        const data = JSON.parse(responseText);
        console.log('✅ PCO approval successful. New status:', data.data?.attributes?.approval_status);

        return Response.json({ 
            success: true,
            data: data,
            new_status: data.data?.attributes?.approval_status,
            token_user_id: tokenUserId
        });

    } catch (error) {
        console.error('❌ Approve request error:', error.message);
        console.error('❌ Stack:', error.stack);
        return Response.json({ 
            error: error.message,
            stack: error.stack
        }, { status: 500 });
    }
});