// Base44 Function: listPendingApprovalsV2
// Endpoint: POST /functions/listPendingApprovalsV2  (Base44 auto-exposes)

import { createClientFromRequest } from "npm:@base44/sdk@0.7.1";

const PCO_BASE = "https://api.planningcenteronline.com";
const LOOKBACK_DAYS = Number(Deno.env.get("PCO_PENDING_LOOKBACK_DAYS") || 30);

async function pcoJson(url, token) {
  const r = await fetch(url, { headers: { Authorization: `Bearer ${token}` } });
  const j = await r.json().catch(() => ({}));
  if (!r.ok) throw new Error(`GET ${url} :: ${r.status} :: ${JSON.stringify(j).slice(0,300)}`);
  return j;
}

// Use service token for server-to-PCO
async function refreshServiceToken(base44, user) {
  const expiresAt = new Date(user.pco_token_expires_at);
  const fiveMinutesFromNow = new Date(Date.now() + 5 * 60 * 1000);

  if (expiresAt > fiveMinutesFromNow) {
    return user.pco_access_token;
  }

  const body = new URLSearchParams({
    grant_type: "refresh_token",
    refresh_token: user.pco_refresh_token,
    client_id: Deno.env.get("PCO_CLIENT_ID"),
    client_secret: Deno.env.get("PCO_CLIENT_SECRET"),
  });
  const r = await fetch(`${PCO_BASE}/oauth/token`, {
    method: "POST",
    headers: { "Content-Type": "application/x-www-form-urlencoded" },
    body
  });
  const j = await r.json().catch(() => ({}));
  if (!r.ok || !j.access_token) throw new Error(`service refresh failed ${r.status} :: ${JSON.stringify(j)}`);
  
  // Update user tokens
  const newExpiresAt = new Date(Date.now() + (j.expires_in * 1000)).toISOString();
  await base44.asServiceRole.entities.User.update(user.id, {
    pco_access_token: j.access_token,
    pco_refresh_token: j.refresh_token,
    pco_token_expires_at: newExpiresAt
  });
  
  return j.access_token;
}

Deno.serve(async (req) => {
  try {
    const base44 = createClientFromRequest(req);
    const currentUser = await base44.auth.me();

    if (!currentUser) {
      return Response.json({ error: 'Unauthorized' }, { status: 401 });
    }

    const users = await base44.asServiceRole.entities.User.filter({ email: currentUser.email });
    const user = users[0];

    if (!user || !user.pco_access_token) {
      return Response.json({ error: 'PCO not connected' }, { status: 400 });
    }

    const { mode = "mygroups", per_page = 100 } = (await req.json().catch(() => ({}))) || {};
    const token = await refreshServiceToken(base44, user);

    // Who am I?
    const me = await pcoJson(`${PCO_BASE}/people/v2/me`, token);
    const meId = me?.data?.id;

    // My approval group ids (only if needed)
    let myGroupIds = [];
    if (mode === "mygroups") {
      const gm = await pcoJson(
        `${PCO_BASE}/calendar/v2/resource_approval_group_memberships?where[person_id]=${meId}&per_page=100&include=resource_approval_group`,
        token
      );
      myGroupIds = (gm.data || [])
        .map(x => x?.relationships?.resource_approval_group?.data?.id)
        .filter(Boolean);
    }

    // Pending only, newest first
    const include = [
      "assigned_to_person",
      "approval_group",
      "event",
      "requested_resources",
      "requested_resources.resource",
      "requested_resources.location"
    ].join(",");

    const url = `${PCO_BASE}/calendar/v2/event_resource_requests` +
      `?where[status]=pending&order=-created_at&per_page=${Math.min(200, Number(per_page))}` +
      `&include=${encodeURIComponent(include)}`;

    const data = await pcoJson(url, token);

    // Filter by mode
    const filtered = (data.data || []).filter(rq => {
      if (mode === "all") return true;
      const ap = rq?.relationships?.assigned_to_person?.data;
      const grp = rq?.relationships?.approval_group?.data;
      if (mode === "mine") return ap?.type === "Person" && ap?.id === meId;
      if (mode === "mygroups") return grp?.id && myGroupIds.includes(grp.id);
      return false;
    });

    // Lookback window
    const sinceMs = Date.now() - LOOKBACK_DAYS * 86400000;
    const recent = filtered.filter(rq => {
      const t = Date.parse(rq?.attributes?.created_at || "");
      return Number.isFinite(t) ? t >= sinceMs : true;
    });

    // Shape for your UI card list
    const inc = Object.fromEntries((data.included || []).map(x => [`${x.type}:${x.id}`, x]));
    const out = recent.map(rq => {
      const evRel = rq?.relationships?.event?.data;
      const ev = evRel ? inc[`${evRel.type}:${evRel.id}`] : null;
      const groupRel = rq?.relationships?.approval_group?.data;
      const group = groupRel ? inc[`${groupRel.type}:${groupRel.id}`] : null;

      // pick first requested resource for summary row (you also show quantity/resource_name)
      const rrRel = (rq?.relationships?.requested_resources?.data || [])[0];
      const rr = rrRel ? inc[`${rrRel.type}:${rrRel.id}`] : null;
      const resRel = rr?.relationships?.resource?.data;
      const res = resRel ? inc[`${resRel.type}:${resRel.id}`] : null;

      return {
        request_id: rq.id,
        pco_created_at: rq.attributes?.created_at,
        approval_group_name: group?.attributes?.name || null,
        event_id: ev?.id || null,
        event_name: ev?.attributes?.name || null,
        event_starts_at: ev?.attributes?.starts_at || null,
        quantity: rr?.attributes?.quantity ?? 1,
        resource_id: resRel?.id || null,
        resource_name: res?.attributes?.name || null,
        // pass through for your modal
        _raw: rq
      };
    });

    return Response.json({
      ok: true,
      mode,
      me: { id: meId, name: me?.data?.attributes?.name },
      count: out.length,
      approvals: out
    });
  } catch (error) {
    console.error('❌ Error:', error);
    return Response.json({ 
      ok: false,
      error: error.message 
    }, { status: 500 });
  }
});