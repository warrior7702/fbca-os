import { createClientFromRequest } from 'npm:@base44/sdk@0.7.1';

Deno.serve(async (req) => {
    try {
        const base44 = createClientFromRequest(req);

        const { user_id, access_token, refresh_token, expires_in, expires_at } = await req.json();

        console.log('📥 savePCOTokens called with:', { user_id, has_access_token: !!access_token, has_refresh_token: !!refresh_token, expires_in, expires_at });

        if (!user_id || !access_token || !refresh_token) {
            return Response.json({ 
                error: 'Missing required fields' 
            }, { status: 400 });
        }

        // Calculate expiration timestamp - handle both expires_in and expires_at
        let expiresAt;
        if (expires_at) {
            // If we got expires_at directly from Vercel, use it
            expiresAt = expires_at;
            console.log('✅ Using provided expires_at:', expiresAt);
        } else if (expires_in && !isNaN(Number(expires_in))) {
            // Calculate from expires_in
            expiresAt = new Date(Date.now() + (Number(expires_in) * 1000)).toISOString();
            console.log('✅ Calculated expires_at from expires_in:', expiresAt);
        } else {
            // Default to 1 hour
            expiresAt = new Date(Date.now() + (3600 * 1000)).toISOString();
            console.log('⚠️ Using default 1 hour expiration:', expiresAt);
        }

        // Get PCO Person ID
        let pcoUserId = null;
        try {
            const meResponse = await fetch('https://api.planningcenteronline.com/people/v2/me', {
                headers: { 'Authorization': `Bearer ${access_token}` }
            });
            
            if (meResponse.ok) {
                const meData = await meResponse.json();
                pcoUserId = meData?.data?.id;
                console.log('✅ Got PCO Person ID:', pcoUserId);
            } else {
                console.log('⚠️ Failed to get PCO Person ID (non-fatal)');
            }
        } catch (error) {
            console.error('⚠️ Error getting PCO Person ID (non-fatal):', error);
        }

        // Update user with tokens and Person ID
        const updateData = {
            pco_access_token: access_token,
            pco_refresh_token: refresh_token,
            pco_token_expires_at: expiresAt
        };

        if (pcoUserId) {
            updateData.pco_user_id = pcoUserId;
        }

        console.log('💾 Updating user:', user_id, 'with fields:', Object.keys(updateData));

        await base44.asServiceRole.entities.User.update(user_id, updateData);

        console.log('✅ Saved PCO tokens for user:', user_id);
        if (pcoUserId) {
            console.log('✅ Saved PCO Person ID:', pcoUserId);
        }

        return Response.json({ 
            success: true,
            pco_user_id: pcoUserId
        });

    } catch (error) {
        console.error('❌ Error saving PCO tokens:', error);
        console.error('Stack:', error.stack);
        return Response.json({ 
            error: error.message,
            details: error.stack
        }, { status: 500 });
    }
});