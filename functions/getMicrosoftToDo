import { createClientFromRequest } from 'npm:@base44/sdk@0.7.1';

Deno.serve(async (req) => {
    try {
        const base44 = createClientFromRequest(req);
        const user = await base44.auth.me();

        if (!user) {
            console.error('No user found');
            return Response.json({ error: 'Unauthorized' }, { status: 401 });
        }

        if (!user.microsoft_access_token) {
            console.error('No Microsoft token');
            return Response.json({ error: 'Microsoft 365 not connected' }, { status: 400 });
        }

        console.log('User has Microsoft token, checking expiry...');

        // Check if token needs refresh
        const expiresAt = new Date(user.microsoft_token_expires_at);
        const now = new Date();
        
        let accessToken = user.microsoft_access_token;

        if (expiresAt <= now) {
            console.log('Token expired, refreshing...');
            try {
                const refreshResponse = await base44.functions.invoke('refreshMicrosoftToken');
                accessToken = refreshResponse.data.access_token;
                console.log('Token refreshed successfully');
            } catch (refreshError) {
                console.error('Token refresh failed:', refreshError);
                return Response.json({ error: 'Token refresh failed' }, { status: 401 });
            }
        }

        console.log('Fetching To Do lists...');

        // Get all task lists
        let listsResponse;
        try {
            listsResponse = await fetch(
                'https://graph.microsoft.com/v1.0/me/todo/lists',
                {
                    headers: {
                        'Authorization': `Bearer ${accessToken}`,
                        'Content-Type': 'application/json'
                    }
                }
            );
        } catch (fetchError) {
            console.error('Network error fetching lists:', fetchError);
            return Response.json({ error: 'Network error', details: fetchError.message }, { status: 500 });
        }

        if (!listsResponse.ok) {
            const errorText = await listsResponse.text();
            console.error('Failed to fetch To Do lists:', listsResponse.status, errorText);
            return Response.json({ 
                error: 'Failed to fetch To Do lists',
                status: listsResponse.status,
                details: errorText 
            }, { status: listsResponse.status });
        }

        const listsData = await listsResponse.json();
        console.log('Found', listsData.value?.length || 0, 'To Do lists');
        
        if (!listsData.value || listsData.value.length === 0) {
            console.log('No lists found, returning empty array');
            return Response.json({ 
                tasks: [],
                count: 0,
                message: 'No To Do lists found'
            });
        }

        const allTasks = [];

        // Fetch tasks from each list
        for (const list of listsData.value) {
            console.log(`Fetching tasks from list: ${list.displayName} (${list.id})`);
            
            try {
                const tasksResponse = await fetch(
                    `https://graph.microsoft.com/v1.0/me/todo/lists/${list.id}/tasks`,
                    {
                        headers: {
                            'Authorization': `Bearer ${accessToken}`,
                            'Content-Type': 'application/json'
                        }
                    }
                );

                if (tasksResponse.ok) {
                    const tasksData = await tasksResponse.json();
                    const incompleteTasks = (tasksData.value || []).filter(task => task.status !== 'completed');
                    console.log(`Found ${incompleteTasks.length} incomplete tasks in ${list.displayName}`);
                    
                    const formattedTasks = incompleteTasks.map(task => ({
                        id: task.id,
                        title: task.title || 'Untitled Task',
                        body: task.body?.content,
                        status: task.status || 'notStarted',
                        importance: task.importance || 'normal',
                        due_date: task.dueDateTime?.dateTime,
                        created_date: task.createdDateTime,
                        list_name: list.displayName,
                        list_id: list.id,
                        url: `https://to-do.office.com/tasks/id/${task.id}/details`,
                        source: 'microsoft_todo'
                    }));
                    
                    allTasks.push(...formattedTasks);
                } else {
                    const errorText = await tasksResponse.text();
                    console.error(`Failed to fetch tasks from list ${list.displayName}:`, tasksResponse.status, errorText);
                }
            } catch (taskError) {
                console.error(`Error fetching tasks from list ${list.displayName}:`, taskError);
            }
        }

        console.log(`Total tasks fetched: ${allTasks.length}`);

        return Response.json({ 
            tasks: allTasks,
            count: allTasks.length
        });

    } catch (error) {
        console.error('Get Microsoft To Do tasks error:', error.message);
        console.error('Stack:', error.stack);
        return Response.json({ 
            error: error.message,
            stack: error.stack 
        }, { status: 500 });
    }
});