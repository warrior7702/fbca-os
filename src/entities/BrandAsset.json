{
  "name": "BrandAsset",
  "type": "object",
  "properties": {
    "asset_type": {
      "type": "string",
      "enum": [
        "logo",
        "icon",
        "wordmark",
        "color",
        "font"
      ],
      "description": "Type of brand asset"
    },
    "name": {
      "type": "string",
      "description": "Asset name (e.g., 'Primary Logo', 'Brand Blue')"
    },
    "file_url": {
      "type": "string",
      "description": "URL to uploaded file (for logos/icons)"
    },
    "color_hex": {
      "type": "string",
      "description": "Hex color code (for colors)"
    },
    "font_name": {
      "type": "string",
      "description": "Font name (for fonts)"
    },
    "font_url": {
      "type": "string",
      "description": "Google Fonts URL or font file URL"
    },
    "usage_notes": {
      "type": "string",
      "description": "Usage guidelines for this asset"
    },
    "is_primary": {
      "type": "boolean",
      "default": false,
      "description": "Is this the primary/default asset of its type"
    }
  },
  "required": [
    "asset_type",
    "name"
  ]
}