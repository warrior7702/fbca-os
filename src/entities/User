{
  "name": "User",
  "type": "object",
  "properties": {
    "display_name": {
      "type": "string",
      "description": "Preferred display name"
    },
    "department": {
      "type": "string",
      "description": "Department or ministry area"
    },
    "role_title": {
      "type": "string",
      "description": "Job title or role"
    },
    "wallpaper": {
      "type": "string",
      "enum": [
        "church_steeple_night",
        "church_building_blue",
        "cross_chrome_blue",
        "cross_white_glow",
        "cross_metal_texture"
      ],
      "default": "cross_white_glow",
      "description": "Selected desktop wallpaper"
    },
    "desktop_layout": {
      "type": "object",
      "description": "Custom desktop icon positions stored as {appId: {row: number, col: number}}"
    },
    "pco_access_token": {
      "type": "string",
      "description": "Planning Center OAuth access token"
    },
    "pco_refresh_token": {
      "type": "string",
      "description": "Planning Center OAuth refresh token"
    },
    "pco_token_expires_at": {
      "type": "string",
      "format": "date-time",
      "description": "When the PCO access token expires"
    },
    "clickup_access_token": {
      "type": "string",
      "description": "ClickUp OAuth access token"
    },
    "clickup_refresh_token": {
      "type": "string",
      "description": "ClickUp OAuth refresh token"
    },
    "clickup_token_expires_at": {
      "type": "string",
      "format": "date-time",
      "description": "When the ClickUp access token expires"
    },
    "microsoft_access_token": {
      "type": "string",
      "description": "Microsoft OAuth access token"
    },
    "microsoft_refresh_token": {
      "type": "string",
      "description": "Microsoft OAuth refresh token"
    },
    "microsoft_token_expires_at": {
      "type": "string",
      "format": "date-time",
      "description": "When the Microsoft access token expires"
    }
  }
}